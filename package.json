{
  "name": "localize-react",
  "version": "2.0.0-next.0",
  "description": "Tiny, type-safe React i18n library built on Context and hooks — dual ESM + CJS, zero runtime deps.",
  "keywords": [
    "react",
    "i18n",
    "l10n",
    "localization",
    "internationalization",
    "translation",
    "context",
    "hooks",
    "typescript"
  ],
  "homepage": "https://github.com/yankouskia/localize-react#readme",
  "bugs": {
    "url": "https://github.com/yankouskia/localize-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yankouskia/localize-react.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aliaksandr Yankouski",
    "email": "aleksandr.yankovskiy@gmail.com",
    "url": "https://github.com/yankouskia"
  },
  "funding": "https://github.com/sponsors/yankouskia",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage .tsbuildinfo",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test run && pnpm typecheck && pnpm pack:check",
    "pack:check": "publint --strict && attw --pack . --ignore-rules cjs-resolves-to-esm",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish",
    "version": "changeset version",
    "prepare": "simple-git-hooks || true"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
