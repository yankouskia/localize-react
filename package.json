{
  "name": "localize-react",
  "version": "2.0.0-next.0",
  "description": "Tiny, type-safe React i18n library built on Context and hooks — dual ESM + CJS, zero runtime deps.",
  "keywords": [
    "react",
    "i18n",
    "l10n",
    "localization",
    "internationalization",
    "translation",
    "context",
    "hooks",
    "typescript"
  ],
  "homepage": "https://github.com/yankouskia/localize-react#readme",
  "bugs": {
    "url": "https://github.com/yankouskia/localize-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yankouskia/localize-react.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aliaksandr Yankouski",
    "email": "aleksandr.yankovskiy@gmail.com",
    "url": "https://github.com/yankouskia"
  },
  "funding": "https://github.com/sponsors/yankouskia",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage .tsbuildinfo",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test run && pnpm typecheck && pnpm pack:check",
    "pack:check": "publint --strict",
    "pack:check:types": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish",
    "version": "changeset version",
    "size": "size-limit",
    "docs": "typedoc",
    "prepare": "simple-git-hooks || true"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <20"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "fflate": "0.8.2"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "name": "ESM (full library)",
      "path": "dist/index.mjs",
      "limit": "2 kB",
      "ignore": [
        "react"
      ]
    },
    {
      "name": "CJS (full library)",
      "path": "dist/index.cjs",
      "limit": "2.5 kB",
      "ignore": [
        "react"
      ]
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.2",
    "@changesets/changelog-github": "0.7",
    "@changesets/cli": "2.31",
    "@eslint/js": "9",
    "@microsoft/api-extractor": "7",
    "@size-limit/preset-small-lib": "12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16",
    "@testing-library/user-event": "14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "9",
    "eslint-plugin-import-x": "4",
    "eslint-plugin-n": "18",
    "eslint-plugin-promise": "7",
    "eslint-plugin-react": "7",
    "eslint-plugin-react-hooks": "7",
    "eslint-plugin-unicorn": "64",
    "globals": "17",
    "jsdom": "29",
    "lint-staged": "17",
    "prettier": "3",
    "publint": "0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rimraf": "6",
    "simple-git-hooks": "2",
    "size-limit": "12",
    "tsup": "8",
    "typedoc": "~0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "8",
    "vite": "8",
    "vitest": "^4.1.6"
  }
}
