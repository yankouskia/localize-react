{
  "name": "localize-react",
  "version": "2.0.0-next.0",
  "description": "Tiny, type-safe React i18n library built on Context and hooks — dual ESM + CJS, zero runtime deps.",
  "keywords": [
    "react",
    "i18n",
    "l10n",
    "localization",
    "internationalization",
    "translation",
    "context",
    "hooks",
    "typescript"
  ],
  "homepage": "https://github.com/yankouskia/localize-react#readme",
  "bugs": {
    "url": "https://github.com/yankouskia/localize-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yankouskia/localize-react.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aliaksandr Yankouski",
    "email": "aleksandr.yankovskiy@gmail.com",
    "url": "https://github.com/yankouskia"
  },
  "funding": "https://github.com/sponsors/yankouskia",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage .tsbuildinfo",
    "dev": "tsup --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test run && pnpm typecheck && pnpm pack:check",
    "pack:check": "publint --strict && attw --pack . --ignore-rules cjs-resolves-to-esm",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish",
    "version": "changeset version",
    "prepare": "simple-git-hooks || true"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.17",
    "@changesets/cli": "2.28",
    "@eslint/js": "9",
    "@size-limit/preset-small-lib": "11",
    "@testing-library/jest-dom": "6",
    "@testing-library/react": "16",
    "@testing-library/user-event": "14",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "9",
    "eslint-plugin-import-x": "4",
    "eslint-plugin-n": "17",
    "eslint-plugin-promise": "7",
    "eslint-plugin-react": "7",
    "eslint-plugin-react-hooks": "5",
    "eslint-plugin-unicorn": "56",
    "globals": "15",
    "jsdom": "25",
    "lint-staged": "15",
    "prettier": "3",
    "publint": "0.3",
    "react": "18",
    "react-dom": "18",
    "rimraf": "6",
    "simple-git-hooks": "2",
    "size-limit": "11",
    "tsup": "8",
    "typedoc": "~0.28.19",
    "typescript": "5",
    "typescript-eslint": "8",
    "vite": "7",
    "vitest": "^4.1.6"
  }
}
